@page
@model SampleBookShop.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "発注履歴一覧";
}

<div class="container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>発注履歴一覧</h1>
        <div>
            <a class="btn btn-primary" asp-page="/Orders/Create">新規発注</a>
        </div>
    </div>

    @if (Model.Orders.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>発注番号</th>
                        <th>発注日</th>
                        <th>仕入先</th>
                        <th>ステータス</th>
                        <th>商品数</th>
                        <th>合計金額</th>
                        <th>納期予定</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td>
                                <a asp-page="/Orders/Detail" asp-route-id="@order.Id" class="text-decoration-none">
                                    @order.OrderNumber
                                </a>
                            </td>
                            <td>@order.OrderDate.ToString("yyyy/MM/dd")</td>
                            <td>@order.SupplierName</td>
                            <td>
                                <span class="badge bg-@(GetStatusBadgeClass(order.Status))">
                                    @order.StatusDisplayName
                                </span>
                            </td>
                            <td>@order.TotalQuantity 冊</td>
                            <td>¥@order.TotalAmount.ToString("N0")</td>
                            <td>
                                @if (order.ExpectedDeliveryDate.HasValue)
                                {
                                    @order.ExpectedDeliveryDate.Value.ToString("yyyy/MM/dd")
                                }
                                else
                                {
                                    <span class="text-muted">未定</span>
                                }
                            </td>
                            <td>
                                <a asp-page="/Orders/Detail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                    詳細
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <h4>発注履歴がありません</h4>
            <p>まだ発注を行っていません。新規発注から始めてください。</p>
            <a class="btn btn-primary" asp-page="/Orders/Create">新規発注</a>
        </div>
    }

    <div class="mt-4">
        <a class="btn btn-secondary" asp-page="/Index">ホームに戻る</a>
    </div>
</div>

@functions {
    private string GetStatusBadgeClass(SampleBookShop.Models.OrderStatus status)
    {
        return status switch
        {
            SampleBookShop.Models.OrderStatus.Pending => "warning",
            SampleBookShop.Models.OrderStatus.Confirmed => "info",
            SampleBookShop.Models.OrderStatus.Processing => "primary",
            SampleBookShop.Models.OrderStatus.Shipped => "secondary",
            SampleBookShop.Models.OrderStatus.Delivered => "success",
            SampleBookShop.Models.OrderStatus.Cancelled => "danger",
            _ => "secondary"
        };
    }
}